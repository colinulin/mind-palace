{
    "compilerOptions": {
        "target": "es2022",
        "module": "esnext",
        "lib": [
            "ESNext"
        ],
        "outDir": "./dist",
        "declaration": true,
        "declarationMap": true,
        "sourceMap": true,
        "strict": true,
        "baseUrl": "./",
        "forceConsistentCasingInFileNames": true,
        "noImplicitThis": true,
        "moduleResolution": "bundler",
    },
    "include": ["src/**/*"],
    "exclude": ["node_modules", "dist"]
}
