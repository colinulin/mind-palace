{
    "compilerOptions": {
        "target": "es2024",
        "module": "esnext",
        "lib": ["ESNext", "DOM", "DOM.Iterable"],
        "jsx": "react-jsx",
        "strict": true,
        "moduleResolution": "bundler",
        "forceConsistentCasingInFileNames": true,
        "noImplicitThis": true,
        "skipLibCheck": true
    },
    "include": ["client/**/*", "server/**/*", "../src/**/*"]
}
